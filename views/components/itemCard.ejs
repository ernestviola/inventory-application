<div class="card">
  <img src="<%= item.item_imageurl %>" alt="Picture of <%= item.item_name %>" />
  <div class="card-body">
    <span class="card-name"><%= item.item_name %></span>
    <span class="card-price">$<%= item.item_price %></span>
    <span class="card-quantity">Qty: <%= item.item_quantity %></span>
  </div>
</div>
