<%
  const vals = typeof formData !== 'undefined' ? formData : (typeof item !== 'undefined' ? item : {});
  const fieldError = (field) => {
    if (typeof errors === 'undefined') return null;
    return errors.find(e => e.path === field) || null;
  };
  const categoryIdVal = typeof item !== 'undefined' ? item.category_id
    : typeof formData !== 'undefined' ? formData.category_id
    : typeof category !== 'undefined' ? category.id
    : '';
%>
<form action="<%= url %>" method="post" class="form">
  <div class="form-group">
    <label class="form-label" for="name">Name</label>
    <input class="form-input<%= fieldError('name') ? ' form-input--error' : '' %>" type="text" id="name" name="name" placeholder="Item name..." value="<%= vals.name || '' %>" />
    <% if (fieldError('name')) { %><span class="form-error"><%= fieldError('name').msg %></span><% } %>
  </div>
  <div class="form-group">
    <label class="form-label" for="quantity">Quantity</label>
    <input class="form-input<%= fieldError('quantity') ? ' form-input--error' : '' %>" type="number" id="quantity" name="quantity" placeholder="0" min="0" value="<%= vals.quantity || '' %>" />
    <% if (fieldError('quantity')) { %><span class="form-error"><%= fieldError('quantity').msg %></span><% } %>
  </div>
  <div class="form-group">
    <label class="form-label" for="price">Price</label>
    <input class="form-input<%= fieldError('price') ? ' form-input--error' : '' %>" type="number" id="price" name="price" placeholder="0.00" min="0" step="0.01" value="<%= vals.price || '' %>" />
    <% if (fieldError('price')) { %><span class="form-error"><%= fieldError('price').msg %></span><% } %>
  </div>
  <div class="form-group">
    <label class="form-label" for="imageurl">Image URL</label>
    <input class="form-input<%= fieldError('imageurl') ? ' form-input--error' : '' %>" type="text" id="imageurl" name="imageurl" placeholder="https://..." value="<%= vals.imageurl || '' %>" />
    <% if (fieldError('imageurl')) { %><span class="form-error"><%= fieldError('imageurl').msg %></span><% } %>
  </div>
  <input type="text" name="category_id" value="<%= categoryIdVal %>" hidden />
  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Save</button>
    <button type="button" class="btn btn-ghost" onclick="this.closest('dialog').close()">Cancel</button>
  </div>
</form>
