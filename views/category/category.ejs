<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel='stylesheet' href='/styles.css'>
    <title>View <%= category.name %></title>
  </head>
  <body>
    <%- include('../components/navbar') %>
    <div class="page-header">
      <h1><%= category.name %></h1>
      <button class="btn btn-primary" onclick="document.getElementById('new-item-dialog').showModal()">+ New Item</button>
    </div>

    <dialog id="new-item-dialog" onclick="if(event.target===this)this.close()">
      <h2 class="dialog-title">New Item</h2>
      <%- include('../components/itemForm', {
        url: '/item/new',
        errors: (typeof openDialog !== 'undefined' && openDialog === 'new-item-dialog') ? errors : undefined,
        formData: (typeof openDialog !== 'undefined' && openDialog === 'new-item-dialog') ? formData : undefined
      }) %>
    </dialog>

    <% if (items) { %>
      <ul class='item-list'>
      <% items.forEach( item => {
        const isEditError = typeof openDialog !== 'undefined' && openDialog === `edit-item-${item.id}`;
      %>
        <li class='item-row'>
          <img src='<%= item.imageurl %>' alt='Picture of <%= item.name %>' class='item-row-img'>
          <span class='item-row-name'><%= item.name %></span>
          <span class='item-row-price'>$<%= item.price %></span>
          <span class='item-row-quantity'>Qty: <%= item.quantity %></span>
          <div class='item-row-actions'>
            <button class='icon-btn' title='Edit' onclick="document.getElementById('edit-item-<%= item.id %>').showModal()">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </button>
            <form action='/item/<%= item.id %>/delete' method='post'>
              <input type='text' name='category_id' value='<%= category.id %>' hidden>
              <button type='submit' class='icon-btn icon-btn--danger' title='Delete'>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
              </button>
            </form>
          </div>
        </li>
        <dialog id="edit-item-<%= item.id %>" onclick="if(event.target===this)this.close()">
          <h2 class="dialog-title">Edit <%= item.name %></h2>
          <%- include('../components/itemForm', {
            url: `/item/${item.id}/update`,
            item: item,
            errors: isEditError ? errors : undefined,
            formData: isEditError ? formData : undefined
          }) %>
        </dialog>
      <% }) %>
      </ul>
    <% } %>

    <% if (typeof openDialog !== 'undefined') { %>
      <script>document.getElementById('<%= openDialog %>').showModal();</script>
    <% } %>
  </body>
</html>
