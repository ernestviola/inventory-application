<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel='stylesheet' href='/styles.css'>
    <title>All Categories</title>
  </head>
  <body>
    <%- include('../components/navbar') %>
    <h1>Categories</h1>
    <form action="/category/new" method="post">
      <legend>New Category</legend>
      <label for="name">
        Name:
        <input type="text" name="name" placeholder="name..." />
      </label>
      <label for="imageUrl">
        URL:
        <input type="text" name="imageUrl" placeholder="url" />
      </label>
      <button type="submit">Submit</button>
    </form>
    <% if (categories) {%>
      <ul class='categories'>
        <% categories.forEach( category => { %>
          <li>
            <a href='/category/<%= category.id %>'>
              <%= category.name %> <img src='<%= category.imageUrl %>' alt=''>
            </a>
            <a href='/category/<%= category.id %>/edit'>Edit</a>
            <form action='/category/<%= category.id %>/delete' method='post'><button type='submit'>Delete</button></form>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </body>
</html>
