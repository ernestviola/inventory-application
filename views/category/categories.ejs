<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel='stylesheet' href='/styles.css'>
    <title>All Categories</title>
  </head>
  <body>
    <%- include('../components/navbar') %>
    <div class="page-header">
      <h1>Categories</h1>
      <button class="btn btn-primary" onclick="document.getElementById('new-category-dialog').showModal()">+ New Category</button>
    </div>

    <%
      const isCreateError = typeof openDialog !== 'undefined' && openDialog === 'new-category-dialog';
      const createVals = isCreateError && typeof formData !== 'undefined' ? formData : {};
      const createFieldError = (field) => {
        if (!isCreateError || typeof errors === 'undefined') return null;
        return errors.find(e => e.path === field) || null;
      };
    %>
    <dialog id="new-category-dialog" onclick="if(event.target===this)this.close()">
      <h2 class="dialog-title">New Category</h2>
      <form action="/category/new" method="post" class="form">
        <div class="form-group">
          <label class="form-label" for="new-name">Name</label>
          <input class="form-input<%= createFieldError('name') ? ' form-input--error' : '' %>" type="text" id="new-name" name="name" placeholder="Category name..." value="<%= createVals.name || '' %>" />
          <% if (createFieldError('name')) { %><span class="form-error"><%= createFieldError('name').msg %></span><% } %>
        </div>
        <div class="form-group">
          <label class="form-label" for="new-imageurl">Image URL</label>
          <input class="form-input<%= createFieldError('imageurl') ? ' form-input--error' : '' %>" type="text" id="new-imageurl" name="imageurl" placeholder="https://..." value="<%= createVals.imageurl || '' %>" />
          <% if (createFieldError('imageurl')) { %><span class="form-error"><%= createFieldError('imageurl').msg %></span><% } %>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Add</button>
          <button type="button" class="btn btn-ghost" onclick="this.closest('dialog').close()">Cancel</button>
        </div>
      </form>
    </dialog>

    <% if (categories) {%>
      <ul class='categories'>
        <% categories.forEach( category => {
          const isEditError = typeof openDialog !== 'undefined' && openDialog === `edit-category-${category.id}`;
          const editErrors = isEditError ? errors : undefined;
          const editFormData = isEditError ? formData : undefined;
        %>
          <li class='category-row'>
            <img src='<%= category.imageurl %>' alt='<%= category.name %>' class='category-row-img'>
            <a href='/category/<%= category.id %>' class='category-row-name'><%= category.name %></a>
            <div class='category-row-actions'>
              <button class='icon-btn' title='Edit' onclick="document.getElementById('edit-category-<%= category.id %>').showModal()">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <form action='/category/<%= category.id %>/delete' method='post'>
                <button type='submit' class='icon-btn icon-btn--danger' title='Delete'>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </button>
              </form>
            </div>
          </li>
          <dialog id="edit-category-<%= category.id %>" onclick="if(event.target===this)this.close()">
            <h2 class="dialog-title">Edit <%= category.name %></h2>
            <%- include('../components/categoryForm', { url: `/category/${category.id}/update`, category: category, errors: editErrors, formData: editFormData }) %>
          </dialog>
        <% }) %>
      </ul>
    <% } %>

    <% if (typeof openDialog !== 'undefined') { %>
      <script>document.getElementById('<%= openDialog %>').showModal();</script>
    <% } %>
  </body>
</html>
