<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel='stylesheet' href='styles.css'>
    <title>Shop</title>
  </head>
  <body>
    <%- include('components/navbar') %>
    <h1>Shop</h1>
    <% if (rows) { %>
      <% rows.forEach(rows => { %>
        <h2><%= rows.category_name %></h2>
        <% if (rows.items) { %>
          <% rows.items.forEach(item => { %>
            <%- include('components/itemCard',{item: item}) %>
          <% }) %>
        <% } %>

      <% }); %>
    <% } %>
  </body>
</html>
